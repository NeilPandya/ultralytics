# syntax=docker/dockerfile:1
FROM pytorch/pytorch:2.11.0-cuda12.8-cudnn9-devel AS builder

# Install build dependencies including git
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    git cmake ninja-build libopenblas-dev python3-dev build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /opt/pytorch
RUN git clone --recursive https://github.com/pytorch/pytorch.git && \
    cd pytorch && \
    git checkout v2.11.0 && \
    git submodule update --init --recursive

ENV CXXFLAGS="-march=znver3 -O3 -fPIC -mno-avx512f -mno-avx512bw -mno-avx512dq"
ENV CFLAGS="-march=znver3 -O3 -fPIC -mno-avx512f -mno-avx512bw -mno-avx512dq"
ENV USE_CUDA=1
ENV TORCH_CUDA_ARCH_LIST="8.6"
# Keep MKL-DNN for other optimizations, but disable AVX-512
ENV USE_MKLDNN=1
ENV DISABLE_AVX512=ON

# Use `--break-system-packages`
# PyTorch base images starting with version 2.11 enforce PEP 668, which prevents global pip installations without explicit opt-in.
WORKDIR /opt/pytorch/pytorch
RUN pip3 install --break-system-packages -r requirements.txt
RUN MAX_JOBS=$(( $(nproc) * 5 / 10 )) python3 setup.py bdist_wheel

# Export the wheel as build artifact
FROM scratch AS export
COPY --from=builder /opt/pytorch/pytorch/dist/*.whl /
