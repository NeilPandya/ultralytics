# Builds ultralytics/ultralytics:latest image on DockerHub https://hub.docker.com/r/ultralytics/ultralytics
# Image is CUDA-optimized for YOLO single/multi-GPU training and inference

# ==============================================================================
# STAGE 1: BUILDER
# Goal: Compile PyTorch from source with AMD 5950X optimizations (-march=native)
# ==============================================================================
FROM pytorch/pytorch:2.9.1-cuda12.8-cudnn9-devel AS builder

# 1. Install Build Dependencies
# We need python3-dev and build tools to compile PyTorch
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    cmake ninja-build git libopenblas-dev python3-pip python3-dev python3-venv \
    build-essential && \
    rm -rf /var/lib/apt/lists/*

# 2. Clone PyTorch (Matching the version from Ultralytics base: 2.9.1)
WORKDIR /opt/pytorch
RUN git clone --recursive https://github.com/pytorch/pytorch.git && \
    cd pytorch && \
    git checkout v2.9.1

# 3. Set Optimization Flags for AMD 5950X (Zen 3) + RTX 3090 (Ampere)
ENV CXXFLAGS="-march=native -O3 -fPIC"
ENV CFLAGS="-march=native -O3 -fPIC"
ENV MAX_JOBS=10
ENV USE_CUDA=1
ENV USE_CUDNN=1
ENV TORCH_CUDA_ARCH_LIST="8.6"
ENV CMAKE_PREFIX_PATH="/usr/local/cuda"

# 4. Build PyTorch as a Python Wheel
# This creates a portable .whl file we can simply pip install in the next stage
WORKDIR /opt/pytorch/pytorch
RUN pip3 install -r requirements.txt
RUN python3 setup.py bdist_wheel


# ==============================================================================
# STAGE 2: RUNTIME (The Ultralytics Environment)
# Goal: Mimic the official Ultralytics Dockerfile exactly, but use our Custom Torch
# ==============================================================================
FROM pytorch/pytorch:2.9.1-cuda12.8-cudnn9-runtime

# 1. Setup Python Environment (Since raw NVIDIA runtime images don't have Python)
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv libopenblas-base && \
    rm -rf /var/lib/apt/lists/*

# 2. Install the Custom Optimized PyTorch Wheel from Stage 1
COPY --from=builder /opt/pytorch/pytorch/dist/*.whl /tmp/
RUN pip3 install /tmp/*.whl && rm /tmp/*.whl

# ------------------------------------------------------------------------------
# START: OFFICIAL ULTRALYTICS CONFIGURATION
# (Directly mapped from the provided Dockerfile)
# ------------------------------------------------------------------------------

# Set environment variables
# Avoid DDP error "MKL_THREADING_LAYER=INTEL is incompatible with libgomp.so.1 library"
# Suppress TensorFlow cuDNN, cuBLAS, and cuFFT Registration Warnings
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    MKL_THREADING_LAYER=GNU \
    OMP_NUM_THREADS=1 \
    TF_CPP_MIN_LOG_LEVEL=3

# Downloads to user config dir
ADD https://github.com/ultralytics/assets/releases/download/v0.0.0/Arial.ttf \
    https://github.com/ultralytics/assets/releases/download/v0.0.0/Arial.Unicode.ttf \
    /root/.config/Ultralytics/

# Install linux packages
# (Includes tools Ultralytics needs: gcc, git, GL libs for OpenCV, etc.)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    gcc git zip unzip wget curl htop libgl1 libglib2.0-0 gnupg libsm6 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install 'uv' (as specified in Ultralytics file)
RUN pip3 install uv

# Create working directory
WORKDIR /ultralytics

# Copy contents and configure git
# (This copies your local forked repo content into the image)
COPY . .

# Configure Git and fix OpenCV dependency (Headless for server/docker environments)
RUN sed -i '/^\[http "https:\/\/github\.com\/"\]/,+1d' .git/config && \
    sed -i'' -e 's/"opencv-python/"opencv-python-headless/' pyproject.toml

# Download Weights (REMOVED: Weights will be managed on the host via mounted volumes)
# ADD https://github.com/ultralytics/assets/releases/download/v8.3.0/yolo11n.pt .


# Install pip packages using 'uv'
# Note: This will verify requirements. Since we already installed PyTorch,
# uv should detect it and satisfy the 'torch' dependency without downloading the generic one.
RUN uv pip install --system -e ".[export]" "onnxruntime-gpu" albumentations faster-coco-eval wandb && \
    # Remove extra build files \
    rm -rf tmp /root/.config/Ultralytics/persistent_cache.json

# ------------------------------------------------------------------------------
# END: OFFICIAL ULTRALYTICS CONFIGURATION
# ------------------------------------------------------------------------------

# Usage Examples -------------------------------------------------------------------------------------------------------

# Build and Push
# t=ultralytics/ultralytics:latest && sudo docker build -f docker/Dockerfile -t $t . && sudo docker push $t

# Pull and Run with access to all GPUs
# t=ultralytics/ultralytics:latest && sudo docker pull $t && sudo docker run -it --ipc=host --gpus all $t

# Pull and Run with access to GPUs 2 and 3 (inside container CUDA devices will appear as 0 and 1)
# t=ultralytics/ultralytics:latest && sudo docker pull $t && sudo docker run -it --ipc=host --gpus '"device=2,3"' $t

# Pull and Run with local directory access
# t=ultralytics/ultralytics:latest && sudo docker pull $t && sudo docker run -it --ipc=host --gpus all -v "$(pwd)"/shared/datasets:/datasets $t

# Kill all
# sudo docker kill $(sudo docker ps -q)

# Kill all image-based
# sudo docker kill $(sudo docker ps -qa --filter ancestor=ultralytics/ultralytics:latest)

# DockerHub tag update
# t=ultralytics/ultralytics:latest tnew=ultralytics/ultralytics:v6.2 && sudo docker pull $t && sudo docker tag $t $tnew && sudo docker push $tnew

# Clean up
# sudo docker system prune -a --volumes

# Update Ubuntu drivers
# https://www.maketecheasier.com/install-nvidia-drivers-ubuntu/

